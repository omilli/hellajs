{
  "name": "hellajs",
  "description": "A reactive JavaScript framework",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "unpkg": "./dist/index.umd.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "release": "release-it"
  },
  "devDependencies": {
    "release-it": "^18.1.2",
    "typescript": "~5.6.2",
    "vite": "^6.0.5",
    "vite-plugin-dts": "^4.5.0"
  },
  "keywords": [
    "javascript",
    "framework",
    "reactive",
    "ui",
    "frontend"
  ],
  "author": "Hella",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mullinghorn/hellajs"
  }
}
